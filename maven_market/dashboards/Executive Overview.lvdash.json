{
  "datasets": [
    {
      "name": "top_products",
      "displayName": "Top 10 Products by Revenue",
      "queryLines": [
        "SELECT\n",
        "  p.product_name,\n",
        "  p.product_brand,\n",
        "  SUM(t.quantity * p.product_retail_price) AS total_revenue,\n",
        "  SUM(t.quantity * (p.product_retail_price - p.product_cost)) AS total_profit,\n",
        "  SUM(t.quantity) AS total_quantity,\n",
        "  AVG(p.margin_pct) AS avg_margin_pct\n",
        "FROM\n",
        "  maven_market_uc.silver.transactions t\n",
        "    JOIN maven_market_uc.gold.dim_product p\n",
        "      ON t.product_id = p.product_id\n",
        "GROUP BY\n",
        "  p.product_name,\n",
        "  p.product_brand\n",
        "ORDER BY\n",
        "  total_revenue DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "yoy_growth",
      "displayName": "YoY Revenue Growth",
      "queryLines": [
        "SELECT\n",
        "  SUM(\n",
        "    CASE\n",
        "      WHEN t.transaction_year = 1997 THEN t.quantity * p.product_retail_price\n",
        "      ELSE 0\n",
        "    END\n",
        "  ) AS rev_1997,\n",
        "  SUM(\n",
        "    CASE\n",
        "      WHEN t.transaction_year = 1998 THEN t.quantity * p.product_retail_price\n",
        "      ELSE 0\n",
        "    END\n",
        "  ) AS rev_1998,\n",
        "  ROUND(\n",
        "    (\n",
        "      SUM(\n",
        "        CASE\n",
        "          WHEN t.transaction_year = 1998 THEN t.quantity * p.product_retail_price\n",
        "          ELSE 0\n",
        "        END\n",
        "      )\n",
        "        - SUM(\n",
        "          CASE\n",
        "            WHEN t.transaction_year = 1997 THEN t.quantity * p.product_retail_price\n",
        "            ELSE 0\n",
        "          END\n",
        "        )\n",
        "    )\n",
        "      / NULLIF(\n",
        "        SUM(\n",
        "          CASE\n",
        "            WHEN t.transaction_year = 1997 THEN t.quantity * p.product_retail_price\n",
        "            ELSE 0\n",
        "          END\n",
        "        ),\n",
        "        0\n",
        "      )\n",
        "      * 100,\n",
        "    2\n",
        "  ) AS yoy_growth_pct\n",
        "FROM\n",
        "  maven_market_uc.silver.transactions t\n",
        "    JOIN maven_market_uc.gold.dim_product p\n",
        "      ON t.product_id = p.product_id"
      ]
    },
    {
      "name": "monthly_trend",
      "displayName": "Monthly Revenue Trend",
      "queryLines": [
        "SELECT\n",
        "  t.transaction_year,\n",
        "  t.transaction_month,\n",
        "  SUM(t.quantity * p.product_retail_price) AS monthly_revenue,\n",
        "  SUM(t.quantity * (p.product_retail_price - p.product_cost)) AS monthly_profit,\n",
        "  SUM(t.quantity * p.product_cost) AS monthly_cost,\n",
        "  COUNT(*) AS transaction_count\n",
        "FROM\n",
        "  maven_market_uc.silver.transactions t\n",
        "    JOIN maven_market_uc.gold.dim_product p\n",
        "      ON t.product_id = p.product_id\n",
        "GROUP BY\n",
        "  t.transaction_year,\n",
        "  t.transaction_month\n",
        "ORDER BY\n",
        "  t.transaction_year,\n",
        "  t.transaction_month"
      ]
    },
    {
      "name": "fact_sales",
      "displayName": "Fact Sales",
      "queryLines": [
        "SELECT\n",
        "  t.transaction_date,\n",
        "  t.stock_date,\n",
        "  t.product_id,\n",
        "  t.customer_id,\n",
        "  t.store_id,\n",
        "  t.quantity,\n",
        "  t.quantity * p.product_retail_price AS revenue,\n",
        "  t.quantity * p.product_cost AS cost,\n",
        "  t.quantity * (p.product_retail_price - p.product_cost) AS gross_profit,\n",
        "  t.transaction_year,\n",
        "  t.transaction_month,\n",
        "  t.transaction_quarter\n",
        "FROM\n",
        "  maven_market_uc.silver.transactions t\n",
        "    JOIN maven_market_uc.gold.dim_product p\n",
        "      ON t.product_id = p.product_id"
      ],
      "columns": [
        {
          "displayName": "Profit Margin %",
          "description": "Profit margin as a percentage: (Total Gross Profit / Total Revenue) × 100",
          "expression": "ROUND(SUM(`gross_profit`) / SUM(`revenue`) * 100, 2)"
        }
      ]
    },
    {
      "name": "rev_cost_unpivot",
      "displayName": "Revenue vs Cost Quarterly",
      "queryLines": [
        "SELECT\n",
        "  t.transaction_quarter,\n",
        "  'Revenue' AS metric_name,\n",
        "  SUM(t.quantity * p.product_retail_price) AS amount\n",
        "FROM\n",
        "  maven_market_uc.silver.transactions t\n",
        "    JOIN maven_market_uc.gold.dim_product p\n",
        "      ON t.product_id = p.product_id\n",
        "GROUP BY\n",
        "  t.transaction_quarter\n",
        "UNION ALL\n",
        "SELECT\n",
        "  t.transaction_quarter,\n",
        "  'Cost' AS metric_name,\n",
        "  SUM(t.quantity * p.product_cost) AS amount\n",
        "FROM\n",
        "  maven_market_uc.silver.transactions t\n",
        "    JOIN maven_market_uc.gold.dim_product p\n",
        "      ON t.product_id = p.product_id\n",
        "GROUP BY\n",
        "  t.transaction_quarter"
      ]
    },
    {
      "name": "returns_analysis",
      "displayName": "Returns Analysis",
      "queryLines": [
        "SELECT\n",
        "  r.return_date,\n",
        "  r.return_year,\n",
        "  r.product_id,\n",
        "  r.store_id,\n",
        "  r.quantity,\n",
        "  r.quantity * p.product_retail_price AS return_revenue,\n",
        "  r.quantity * p.product_cost AS return_cost,\n",
        "  r.return_month AS month\n",
        "FROM\n",
        "  maven_market_uc.silver.returns r\n",
        "    JOIN maven_market_uc.gold.dim_product p\n",
        "      ON r.product_id = p.product_id"
      ]
    },
    {
      "name": "customer_analysis",
      "displayName": "Customer Analysis",
      "queryLines": [
        "SELECT\n",
        "  t.customer_id,\n",
        "  c.full_name,\n",
        "  c.customer_country,\n",
        "  c.member_card,\n",
        "  c.yearly_income,\n",
        "  c.gender,\n",
        "  t.quantity * p.product_retail_price AS revenue,\n",
        "  t.quantity * (p.product_retail_price - p.product_cost) AS gross_profit,\n",
        "  t.quantity\n",
        "FROM\n",
        "  maven_market_uc.silver.transactions t\n",
        "    JOIN maven_market_uc.silver.customers c\n",
        "      ON t.customer_id = c.customer_id\n",
        "      AND c.__END_AT IS NULL\n",
        "    JOIN maven_market_uc.gold.dim_product p\n",
        "      ON t.product_id = p.product_id"
      ],
      "columns": [
        {
          "displayName": "Avg Revenue Per Customer",
          "description": "Average revenue per unique customer",
          "expression": "SUM(`revenue`) / COUNT(DISTINCT `customer_id`)"
        }
      ]
    }
  ],
