{
  "datasets": [
    {
      "name": "regional_facts",
      "displayName": "Regional Sales Facts",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  maven_market_uc.gold.agg_regional_sales"
      ],
      "columns": [
        {
          "displayName": "month_date",
          "description": "First day of month from year/month for trend charts",
          "expression": "MAKE_DATE(`transaction_year`, `transaction_month`, 1)"
        }
      ]
    },
    {
      "name": "sales_with_stores",
      "displayName": "Sales with Store Details",
      "queryLines": [
        "SELECT\n",
        "  a.transaction_year,\n",
        "  a.transaction_month,\n",
        "  a.region_id,\n",
        "  a.store_id,\n",
        "  a.store_name,\n",
        "  a.total_store_revenue,\n",
        "  a.total_items_sold,\n",
        "  s.store_city,\n",
        "  s.store_state,\n",
        "  s.store_country,\n",
        "  s.store_type,\n",
        "  s.total_sqft,\n",
        "  r.sales_district,\n",
        "  r.sales_region\n",
        "FROM\n",
        "  maven_market_uc.gold.agg_regional_sales a\n",
        "    JOIN maven_market_uc.gold.dim_store s\n",
        "      ON a.store_id = s.store_id\n",
        "    JOIN maven_market_uc.gold.dim_region r\n",
        "      ON a.region_id = r.region_id"
      ]
    }
  ],
