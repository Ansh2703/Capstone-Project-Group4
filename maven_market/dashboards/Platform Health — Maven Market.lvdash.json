{
  "datasets": [
    {
      "name": "gold_summary",
      "displayName": "Gold Summary",
      "queryLines": [
        "SELECT\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(*)\n",
        "    FROM\n",
        "      maven_market_uc.gold.fact_sales\n",
        "  ) AS total_sales_rows,\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(*)\n",
        "    FROM\n",
        "      maven_market_uc.gold.fact_returns\n",
        "  ) AS total_return_rows,\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(DISTINCT customer_id)\n",
        "    FROM\n",
        "      maven_market_uc.gold.dim_customer\n",
        "  ) AS unique_customers,\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(DISTINCT product_id)\n",
        "    FROM\n",
        "      maven_market_uc.gold.dim_product\n",
        "  ) AS unique_products,\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(DISTINCT store_id)\n",
        "    FROM\n",
        "      maven_market_uc.gold.dim_store\n",
        "  ) AS unique_stores,\n",
        "  (\n",
        "    SELECT\n",
        "      ROUND(SUM(revenue), 2)\n",
        "    FROM\n",
        "      maven_market_uc.gold.fact_sales\n",
        "  ) AS total_revenue,\n",
        "  (\n",
        "    SELECT\n",
        "      MAX(gold_loaded_at)\n",
        "    FROM\n",
        "      maven_market_uc.gold.fact_sales\n",
        "  ) AS last_gold_refresh"
      ]
    },
    {
      "name": "layer_counts",
      "displayName": "Data Layer Counts",
      "queryLines": [
        "SELECT\n",
        "  'Bronze' AS layer,\n",
        "  'transactions' AS table_name,\n",
        "  COUNT(*) AS row_count\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_transactions\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze',\n",
        "  'orders_kafka',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_orders_kafka\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze',\n",
        "  'inventory_kafka',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_inventory_kafka\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze',\n",
        "  'customers',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_customers\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze',\n",
        "  'products',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_products\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze',\n",
        "  'regions',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_regions\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze',\n",
        "  'stores',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_stores\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze',\n",
        "  'return',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_return\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze',\n",
        "  'calendar',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_calendar\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver',\n",
        "  'transactions',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.silver.transactions\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver',\n",
        "  'orders',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.silver.orders\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver',\n",
        "  'inventory',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.silver.inventory\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver',\n",
        "  'customers',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.silver.customers\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver',\n",
        "  'products',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.silver.products\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver',\n",
        "  'regions',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.silver.regions\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver',\n",
        "  'stores',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.silver.stores\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver',\n",
        "  'returns',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.silver.returns\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver',\n",
        "  'calendar',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.silver.calendar\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'fact_sales',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.fact_sales\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'fact_returns',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.fact_returns\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'dim_customer',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.dim_customer\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'dim_product',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.dim_product\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'dim_store',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.dim_store\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'dim_region',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.dim_region\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'dim_date',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.dim_date\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'agg_executive_overview',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.agg_executive_overview\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'agg_regional_sales',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.agg_regional_sales\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'agg_customer_ltv',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.agg_customer_ltv\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'agg_ops_inventory_alerts',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.agg_ops_inventory_alerts\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'agg_ops_orders_per_minute',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.agg_ops_orders_per_minute\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold',\n",
        "  'agg_store_space_utilization',\n",
        "  COUNT(*)\n",
        "FROM\n",
        "  maven_market_uc.gold.agg_store_space_utilization"
      ]
    },
    {
      "name": "data_freshness",
      "displayName": "Data Freshness",
      "queryLines": [
        "SELECT\n",
        "  'Bronze Transactions' AS source,\n",
        "  'Bronze' AS layer,\n",
        "  MAX(ingestion_time) AS last_updated\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_transactions\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze Orders Kafka',\n",
        "  'Bronze',\n",
        "  MAX(ingestion_time)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_orders_kafka\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze Inventory Kafka',\n",
        "  'Bronze',\n",
        "  MAX(ingestion_time)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_inventory_kafka\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze Customers',\n",
        "  'Bronze',\n",
        "  MAX(ingestion_time)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_customers\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Bronze Products',\n",
        "  'Bronze',\n",
        "  MAX(ingestion_time)\n",
        "FROM\n",
        "  maven_market_uc.bronze.bronze_products\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver Transactions',\n",
        "  'Silver',\n",
        "  MAX(silver_ingestion_time)\n",
        "FROM\n",
        "  maven_market_uc.silver.transactions\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver Orders',\n",
        "  'Silver',\n",
        "  MAX(silver_ingestion_time)\n",
        "FROM\n",
        "  maven_market_uc.silver.orders\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Silver Inventory',\n",
        "  'Silver',\n",
        "  MAX(silver_ingestion_time)\n",
        "FROM\n",
        "  maven_market_uc.silver.inventory\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold Fact Sales',\n",
        "  'Gold',\n",
        "  MAX(gold_loaded_at)\n",
        "FROM\n",
        "  maven_market_uc.gold.fact_sales\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Gold Fact Returns',\n",
        "  'Gold',\n",
        "  MAX(gold_loaded_at)\n",
        "FROM\n",
        "  maven_market_uc.gold.fact_returns\n",
        "ORDER BY\n",
        "  layer,\n",
        "  source"
      ]
    }
  ],
